SWIFTBATCH_ENV=development

SWIFTBATCH_API_ADDR=:8080
SWIFTBATCH_API_PUBLISHED_PORT=18080
SWIFTBATCH_API_READ_TIMEOUT=10s
SWIFTBATCH_API_WRITE_TIMEOUT=15s
SWIFTBATCH_API_SHUTDOWN_TIMEOUT=10s

SWIFTBATCH_WORKER_CONCURRENCY=4
SWIFTBATCH_WORKER_JOB_TIMEOUT=2m
SWIFTBATCH_WORKER_METRICS_ADDR=:8081
SWIFTBATCH_WORKER_METRICS_PUBLISHED_PORT=18081
SWIFTBATCH_WORKER_POLL_TIMEOUT=5s

SWIFTBATCH_POSTGRES_HOST=postgres
SWIFTBATCH_POSTGRES_PORT=5432
SWIFTBATCH_POSTGRES_USER=swiftbatch
SWIFTBATCH_POSTGRES_PASSWORD=swiftbatch
SWIFTBATCH_POSTGRES_DB=swiftbatch
SWIFTBATCH_POSTGRES_SSLMODE=disable

SWIFTBATCH_REDIS_ADDR=redis:6379
SWIFTBATCH_REDIS_PASSWORD=
SWIFTBATCH_REDIS_DB=0
SWIFTBATCH_REDIS_QUEUE_KEY=swiftbatch:jobs
SWIFTBATCH_REDIS_DLQ_KEY=swiftbatch:jobs:dlq
SWIFTBATCH_REDIS_MAX_RETRIES=3

SWIFTBATCH_STORAGE_ENDPOINT=minio:9000
SWIFTBATCH_STORAGE_PUBLIC_BASE_URL=http://localhost:9000
SWIFTBATCH_STORAGE_ACCESS_KEY=minioadmin
SWIFTBATCH_STORAGE_SECRET_KEY=minioadmin
SWIFTBATCH_STORAGE_BUCKET=swiftbatch
SWIFTBATCH_STORAGE_REGION=us-east-1
SWIFTBATCH_STORAGE_USE_SSL=false
SWIFTBATCH_STORAGE_UPLOAD_URL_TTL=15m
SWIFTBATCH_STORAGE_DOWNLOAD_URL_TTL=30m
