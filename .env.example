PHOTON_ENV=development

PHOTON_API_ADDR=:8080
PHOTON_API_PUBLISHED_PORT=18080
PHOTON_API_READ_TIMEOUT=10s
PHOTON_API_WRITE_TIMEOUT=15s
PHOTON_API_SHUTDOWN_TIMEOUT=10s
PHOTON_API_RATE_LIMIT_ENABLED=true
PHOTON_API_RATE_LIMIT_CLIENT_TTL=30m
PHOTON_API_PRESIGN_RATE_LIMIT_PER_MINUTE=20
PHOTON_API_PRESIGN_RATE_LIMIT_BURST=5
PHOTON_API_JOBS_CREATE_RATE_LIMIT_PER_MINUTE=30
PHOTON_API_JOBS_CREATE_RATE_LIMIT_BURST=10
PHOTON_API_JOBS_RETRY_RATE_LIMIT_PER_MINUTE=6
PHOTON_API_JOBS_RETRY_RATE_LIMIT_BURST=2

PHOTON_WORKER_CONCURRENCY=4
PHOTON_WORKER_JOB_TIMEOUT=2m
PHOTON_WORKER_METRICS_ADDR=:8081
PHOTON_WORKER_METRICS_PUBLISHED_PORT=18081
PHOTON_WORKER_POLL_TIMEOUT=5s

PHOTON_CLEANUP_ENABLED=true
PHOTON_CLEANUP_INTERVAL=6h
PHOTON_CLEANUP_JOB_RETENTION=168h
PHOTON_CLEANUP_DLQ_RETENTION=168h
PHOTON_CLEANUP_BATCH_SIZE=50
PHOTON_CLEANUP_STARTUP_JITTER=0s

PHOTON_POSTGRES_HOST=postgres
PHOTON_POSTGRES_PORT=5432
PHOTON_POSTGRES_USER=photon
PHOTON_POSTGRES_PASSWORD=photon
PHOTON_POSTGRES_DB=photon
PHOTON_POSTGRES_SSLMODE=disable

PHOTON_REDIS_ADDR=redis:6379
PHOTON_REDIS_PASSWORD=
PHOTON_REDIS_DB=0
PHOTON_REDIS_QUEUE_KEY=photon:jobs
PHOTON_REDIS_DLQ_KEY=photon:jobs:dlq
PHOTON_REDIS_MAX_RETRIES=3

PHOTON_STORAGE_ENDPOINT=minio:9000
PHOTON_STORAGE_PUBLIC_BASE_URL=http://localhost:9000
PHOTON_STORAGE_ACCESS_KEY=minioadmin
PHOTON_STORAGE_SECRET_KEY=minioadmin
PHOTON_STORAGE_BUCKET=photon
PHOTON_STORAGE_REGION=us-east-1
PHOTON_STORAGE_USE_SSL=false
PHOTON_STORAGE_UPLOAD_URL_TTL=15m
PHOTON_STORAGE_DOWNLOAD_URL_TTL=30m
