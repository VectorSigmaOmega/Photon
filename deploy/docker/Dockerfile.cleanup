FROM golang:1.25 AS builder

WORKDIR /src

COPY go.mod ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/cleanup ./cmd/cleanup

FROM gcr.io/distroless/static-debian12

WORKDIR /app

COPY --from=builder /out/cleanup /app/cleanup

ENTRYPOINT ["/app/cleanup"]
CMD ["serve"]
